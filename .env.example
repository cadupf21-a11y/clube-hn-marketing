# Copie este arquivo para .env.local e preencha com as credenciais do seu projeto Supabase
# (Project Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key: usada apenas em codigo server-side (nunca exponha no client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# n8n (envio de disparos via WhatsApp - modulo Disparos do /admin)
# Webhook que recebe { disparo_id, mensagem, destinatarios: [{ membro_id, telefone }] },
# responde de imediato com { enviados } e processa o envio em background
# (com throttle/anti-ban), atualizando depois disparos.status e total_enviados.
N8N_DISPARO_WEBHOOK_URL=https://n8n.exemplo.com/webhook/disparo-whatsapp

# Evolution API (fallback usado quando N8N_DISPARO_WEBHOOK_URL nao esta configurado)
EVOLUTION_API_URL=https://n8n-evolution-api.k41knm.easypanel.host
EVOLUTION_API_KEY=429683C4C977415CAAFCCE10F7D57E11
EVOLUTION_INSTANCE=nome-da-instancia

# JID do grupo de WhatsApp usado pelos disparos de grupo (modulo Disparos do /admin)
WHATSAPP_GRUPO_JID=120363408470313611@g.us

# Secret usado pelo n8n para chamar POST /api/disparos/processar-agendados
# (header x-cron-secret), que processa disparos agendados (individuais e de grupo)
CRON_SECRET=defina-um-segredo-forte
